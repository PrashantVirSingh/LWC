import { LightningElement,api } from 'lwc';
export default class DyanmicSLDS extends LightningElement {

@api objectApiName;

get computeClass(){

	if(this.objectApiName === 'Account'){
		return ["slds-box", "slds-theme_alert-texture", "slds-theme_success"];
	}else{
		return ["slds-box", "slds-theme_alert-texture", "slds-theme_error"];
	}
	
}
}
